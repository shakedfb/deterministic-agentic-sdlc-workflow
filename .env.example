# LLM Providers
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# LangSmith Observability
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_PROJECT=agentic-sdlc
LANGCHAIN_TRACING_V2=true

# Temporal
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=agentic-sdlc
TEMPORAL_TASK_QUEUE=sdlc-workflow

# Redis
REDIS_URL=redis://localhost:6379/0

# PostgreSQL (LangGraph checkpoint store)
POSTGRES_URL=postgresql://agentic:agentic@localhost:5432/agentic_sdlc

# E2B Sandbox
E2B_API_KEY=e2b_...

# Pinecone Vector DB
PINECONE_API_KEY=pc-...
PINECONE_INDEX=agentic-sdlc-memory

# Jira
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_API_TOKEN=...
JIRA_USER_EMAIL=...

# GitHub
GITHUB_TOKEN=ghp_...
GITHUB_OWNER=your-org
GITHUB_REPO=your-repo

# Slack (HITL notifications)
SLACK_BOT_TOKEN=xoxb-...
SLACK_HITL_CHANNEL=C0123456789

# Terraform
TF_STATE_BUCKET=your-tf-state-bucket
TF_STATE_REGION=us-east-1
