# ──────────────────────────────────────────────────────────────
# LLM Provider Configuration (REQUIRED — pick ONE provider)
# ──────────────────────────────────────────────────────────────

# Provider: openai | anthropic | ollama | openai-compatible
LLM_PROVIDER=openai

# Model name (empty = provider default: gpt-4o / claude-sonnet / llama3.1)
LLM_MODEL=

# API key (generic — or use provider-specific keys below)
LLM_API_KEY=

# Base URL (required for ollama and openai-compatible)
LLM_BASE_URL=

# Temperature (0.0 = deterministic)
LLM_TEMPERATURE=0.0

# ── Quick-start examples ──────────────────────────────────────
#
# OpenAI:
#   LLM_PROVIDER=openai
#   LLM_API_KEY=sk-...
#   LLM_MODEL=gpt-4o
#
# Anthropic:
#   LLM_PROVIDER=anthropic
#   LLM_API_KEY=sk-ant-...
#   LLM_MODEL=claude-sonnet-4-20250514
#
# Ollama (no API key needed):
#   LLM_PROVIDER=ollama
#   LLM_MODEL=llama3.1
#   LLM_BASE_URL=http://localhost:11434
#
# LM Studio / vLLM / any OpenAI-compatible:
#   LLM_PROVIDER=openai-compatible
#   LLM_BASE_URL=http://localhost:1234/v1
#   LLM_MODEL=local-model
# ──────────────────────────────────────────────────────────────

# Provider-specific keys (fallback when LLM_API_KEY is empty)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# LangSmith Observability (optional — tracing degrades gracefully)
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_PROJECT=agentic-sdlc
LANGCHAIN_TRACING_V2=true

# Temporal (required for workflow orchestration)
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=agentic-sdlc
TEMPORAL_TASK_QUEUE=sdlc-workflow

# Redis (optional — falls back to in-memory)
REDIS_URL=redis://localhost:6379/0

# PostgreSQL (optional — LangGraph checkpointer falls back to MemorySaver)
POSTGRES_URL=postgresql://agentic:agentic@localhost:5432/agentic_sdlc

# E2B Sandbox (optional — falls back to simulated execution)
E2B_API_KEY=e2b_...

# Pinecone Vector DB (optional — falls back to in-memory / empty results)
PINECONE_API_KEY=pc-...
PINECONE_INDEX=agentic-sdlc-memory

# Jira (optional — local_trigger.py bypasses Jira entirely)
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_API_TOKEN=...
JIRA_USER_EMAIL=...

# GitHub (optional)
GITHUB_TOKEN=ghp_...
GITHUB_OWNER=your-org
GITHUB_REPO=your-repo

# Slack (optional — HITL notifications fall back to console)
SLACK_BOT_TOKEN=xoxb-...
SLACK_HITL_CHANNEL=C0123456789

# Terraform (optional)
TF_STATE_BUCKET=your-tf-state-bucket
TF_STATE_REGION=us-east-1
